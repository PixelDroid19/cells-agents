{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node hooks/scripts/cells-session-context.js",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node hooks/scripts/cells-pretool-policy.js",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node hooks/scripts/cells-stop-reminder.js",
        "timeout": 10
      }
    ]
  }
}
